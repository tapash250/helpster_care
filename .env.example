# Helpster Care — environment variable template.
# Copy to `.env` and fill in real values. NEVER commit the real `.env`
# (see AGENTS.md §81 Encryption Policy and §167 Environment Variables).

# --- Supabase ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Service-role key belongs ONLY in Supabase Secrets / Edge Function env, never the app.
# SUPABASE_SERVICE_ROLE_KEY=server-side-only

# --- PowerSync ---
POWERSYNC_URL=https://your-instance.powersync.journeyapps.com

# --- App configuration ---
APP_ENV=development            # development | staging | production
APP_NAME=Helpster Care
DEFAULT_LOCALE=en              # en | bn
SESSION_TIMEOUT_MINUTES=30

# --- Feature flags (server-controlled in production; see §168) ---
FEATURE_OCR=false
FEATURE_AI_SUMMARY=false
FEATURE_TELEMEDICINE=false
FEATURE_DONOR_PORTAL=false
FEATURE_MEDICINE_INVENTORY=false
